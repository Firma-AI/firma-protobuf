# Single source of truth for the versions of the dev tools we install.
#
# Consumed by:
#   - the Justfile recipes, via `set dotenv-load` (KEY=value exposed as $KEY)
#   - CI workflows, via a "Load tool versions" step that appends the KEY=value
#     lines to $GITHUB_ENV, after which steps reference ${{ env.<KEY> }}
#
# Format rules (must satisfy both consumers):
#   - KEY=value only, one per line; no quotes
#   - no inline comments after a value
#
# NOT here: GitHub Actions `uses:` refs. GitHub forbids expressions in `uses:`,
# so those stay pinned in each workflow.
DPRINT_VERSION=0.54.0
CARGO_AUDIT_VERSION=0.22.2
CARGO_DENY_VERSION=0.19.9
